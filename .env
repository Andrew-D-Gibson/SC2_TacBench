# Real overrides — all other settings use the defaults defined in settings.py.
# See .env.example for the full list of available options.

TACBENCH_MODEL_NAME=qwen3:8b

TACBENCH_K_STEPS=15
TACBENCH_REALTIME=true
TACBENCH_SHOW_LOCATIONS=false

TACBENCH_SHOW_HISTORY=true
TACBENCH_HISTORY_LENGTH=5

TACBENCH_SHOW_TERRAIN=false