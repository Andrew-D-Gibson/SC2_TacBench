# TacBench configuration reference.
# Copy relevant lines to .env and remove the leading # to override a default.
# All keys must be prefixed with TACBENCH_.

# --- Game setup ---
# TACBENCH_MAP=tacbench_01
# TACBENCH_PLAYER_RACE=Terran
# TACBENCH_OPPONENT_RACE=Terran
# TACBENCH_OPPONENT_DIFFICULTY=Easy
# TACBENCH_REALTIME=false

# --- Episode limits ---
# TACBENCH_K_STEPS=30            # how often (in steps) to call the LLM
# TACBENCH_MAX_STEPS=5000        # hard step cap before the episode is force-ended

# --- LLM ---
# TACBENCH_BOT_TYPE=ollama                            # ollama | claude | fairlib
# ANTHROPIC_API_KEY=sk-ant-...                        # required when BOT_TYPE=claude
# TACBENCH_MODEL_NAME=qwen3:8b                        # Ollama model
# TACBENCH_MODEL_NAME=claude-haiku-4-5-20251001       # Claude (fast, ~1s)
# TACBENCH_MODEL_NAME=claude-sonnet-4-6               # Claude (smarter, ~2s)
# TACBENCH_FALLBACK_DIRECTIVE=HOLD_POSITION

# --- Observation sections (set to false to drop from the LLM prompt) ---
# TACBENCH_SHOW_YOUR_UNITS=true
# TACBENCH_SHOW_YOUR_STRUCTURES=true
# TACBENCH_SHOW_ENEMY_UNITS=true
# TACBENCH_SHOW_ENEMY_STRUCTURES=true
# TACBENCH_SHOW_SUPPLY=true
# TACBENCH_SHOW_GAME_TIME=true
# TACBENCH_SHOW_LOCATIONS=true

# --- Debugging ---
# TACBENCH_SHOW_LLM_PROMPT=false   # print full LLM input to console each call

# --- Historical context (compressed prior decisions appended to each prompt) ---
# Warning: each history entry adds ~50-100 tokens; watch inference latency.
# TACBENCH_SHOW_HISTORY=false
# TACBENCH_HISTORY_LENGTH=3

# --- Terrain map (static ASCII grid appended to each prompt) ---
# Warning: adds ~500-1500 tokens depending on map size and downsample factor.
# TACBENCH_SHOW_TERRAIN=false
# TACBENCH_TERRAIN_DOWNSAMPLE=4   # higher = fewer tokens, less detail (try 8 for large maps)
